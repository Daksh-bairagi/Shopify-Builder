# Google Cloud / Vertex AI (used by langchain_google_vertexai for structured-output calls)
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
GOOGLE_CLOUD_LOCATION=us-central1
VERTEX_MODEL=gemini-2.0-flash

# Gemini API (direct) — required for the AI-visibility live probe via google-genai SDK
GEMINI_API_KEY=

# Optional extra providers for the AI-visibility probe.
# Each provider activates only if its key is set; missing keys degrade to a "missing_key"
# entry in /jobs/{id}/ai-visibility's `providers` map.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
PERPLEXITY_API_KEY=
PERPLEXITY_MODEL=sonar-pro
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-sonnet-4-6

# Database
DATABASE_URL=postgresql://user:pass@localhost:5432/shopmirror

# Search API (for competitor discovery)
SERPAPI_KEY=...    # OR use DDGS (DuckDuckGo, free, no key needed)

# Shopify (optional for admin-token flows and seed_dev_store.py)
SHOPIFY_STORE_DOMAIN=your-store.myshopify.com
SHOPIFY_ADMIN_ACCESS_TOKEN=
SHOPIFY_CLIENT_ID=
SHOPIFY_CLIENT_SECRET=
SHOPIFY_LOCATION_ID=
SHOPIFY_ONLINE_STORE_PUBLICATION_ID=

# App
ENVIRONMENT=development
LOG_LEVEL=INFO
MAX_PRODUCTS_PER_ANALYSIS=500
MAX_CRAWL_PAGES=5
FREE_TIER_MCP_QUESTIONS=3
PAID_TIER_MCP_QUESTIONS=10
FREE_TIER_PERCEPTION_PRODUCTS=0
PAID_TIER_PERCEPTION_PRODUCTS=5
